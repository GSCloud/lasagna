defaults:
  language: cs

home:
  path: /
  country: [
    default: '/en'
    localhost: '/cs'
    CZ: '/cs'
    XX: '/en'
  ]
  assert_httpcode: 303

cs:
  path: /cs
  sitemap: true

en:
  path: /en
  sitemap: true
  language: en

APIDemo:
  language: en
  path: /api/v1/APIDemo
  api: true
  api_description: "API demo"
  api_info: "Returns (JSON): array of object records."
  assert_json: true
  presenter: api
