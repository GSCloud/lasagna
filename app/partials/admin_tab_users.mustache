<div id="users" class="col s12">
  <div class="">

    <!-- groups -->
    <div class="row center extrapadding">
      <h4>{{ l.a_groups_permissions }}</h4>
      <div class="white-text">
        <div class="row center">

          <strong>🧑‍🤝‍🧑 ADMIN</strong>
          <div class="container">
            <div class="orange-text">{{#admin_groups.admin}}{{ . }} {{/admin_groups.admin}}
              {{^admin_groups.admin}}<i class="red-text fas fa-times"></i>{{/admin_groups.admin}}
            </div>
          </div>
          {{#admin_groups.editor}}

          <strong>🧑‍🤝‍🧑 EDITOR</strong>
          <div class="container">
            <p class="orange-text">{{#admin_groups.editor}}{{ . }} {{/admin_groups.editor}}</p>
          </div>
          {{/admin_groups.editor}}

          {{#admin_groups.tester}}
          <strong>🧑‍🤝‍🧑 TESTER</strong>
          <div class="container">
            <p class="orange-text">{{#admin_groups.tester}}{{ . }} {{/admin_groups.tester}}</p>
          </div>
          {{/admin_groups.tester}}

          {{#admin_groups.default}}
          <strong>🧑‍🤝‍🧑 DEFAULT</strong>
          <div class="container">
            <p class="orange-text">{{#admin_groups.default}}{{ . }} {{/admin_groups.default}}</p>
          </div>
          {{/admin_groups.default}}

        </div>
      </div>
    </div>

  </div>
  <br>
</div>
