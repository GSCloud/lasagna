<div id="users" class="col s12">
    <!-- groups -->
    <div class="container">
      <h4>{{ l.a_groups_permissions }}</h4>
      <div class="white-text">
        <div class="row center">

          {{#admin_groups}}
          <strong>🧑‍🤝‍🧑 ADMIN</strong>
          <div class="container">
            <div class="orange-text">{{#admin_groups.admin}}{{ . }} {{/admin_groups.admin}}
              {{^admin_groups.admin}}<i class="red-text fas fa-times"></i>{{/admin_groups.admin}}
            </div>
          </div>
          <br>
          <br>

          <strong>🧑‍🤝‍🧑 MANAGER</strong>
          <div class="container">
            <div class="orange-text">{{#admin_groups.manager}}{{ . }} {{/admin_groups.manager}}
              {{^admin_groups.manager}}<i class="red-text fas fa-times"></i>{{/admin_groups.manager}}
            </div>
          </div>
          <br>
          <br>

          <strong>🧑‍🤝‍🧑 EDITOR</strong>
          <div class="container">
            <div class="orange-text">{{#admin_groups.editor}}{{ . }} {{/admin_groups.editor}}
              {{^admin_groups.editor}}<i class="red-text fas fa-times"></i>{{/admin_groups.editor}}
            </div>
          </div>
          <br>
          {{/admin_groups}}

        </div>
      </div>
    </div>
</div>
