<div id="fn" class="container">

  <h4><i class="fa-solid fa-robot"></i> fn</h4>
  <p>{{ l.a_remote_fn_info }}</p>

  <div class="row center extrapadding">
    <div class="white">
      <label for="RemoteFnSelect">{{ l.a_remotefns }}</label>
      <select id="RemoteFnSelect">
      {{#admin_group_admin}}
        <option value="" disabled selected>&hellip;</option>
        <option value="CoreUpdateRemote">🍃 Refresh CSV Data</option>
        <option value="FlushCacheRemote">🍃 Flush All Caches</option>
        <option value="AuditLogJSONRemote">📄 get Audit Log in JSON format</option>
        <option value="ErrorsJSONRemote">📄 get Errors in JSON format</option>
        <option value="WarningsJSONRemote">📄 get Warnings in JSON format</option>
        <option value="MessagesJSONRemote">📄 get Messages in JSON format</option>
        <option value="" disabled>&hellip;</option>
        <option value="RebuildNonceRemote">🔑 Rebuild Auth Nonce</option>
        <option value="RebuildSecureKeyRemote">🔑 Rebuild Auth Cookie Secure Key</option>
        <option value="RebuildAdminKeyRemote">⚠️ Rebuild Admin Secure Key</option>
      {{/admin_group_admin}}
      {{#admin_group_manager}}
        <option value="" disabled selected>&hellip;</option>
        <option value="CoreUpdateRemote">🍃 Refresh CSV Data</option>
        <option value="FlushCacheRemote">🍃 Flush All Caches</option>
        <option value="" disabled>&hellip;</option>
        <option value="RebuildNonceRemote">🔑 Rebuild Auth Nonce</option>
        <option value="RebuildSecureKeyRemote">🔑 Rebuild Auth Cookie Secure Key</option>
      {{/admin_group_manager}}
      {{#admin_group_editor}}
        <option value="" disabled selected>&hellip;</option>
        <option value="CoreUpdateRemote">🍃 Refresh CSV Data</option>
        <option value="FlushCacheRemote">🍃 Flush All Caches</option>
      {{/admin_group_editor}}
      </select>
    </div>
  </div>

</div>
