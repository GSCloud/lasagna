### DOCKER TESSERACT LASAGNA

dbg: FALSE

# core
app: lasagna
canonical_url: "https://lasagna.gscloud.cz/"
date_default_timezone: "Europe/Prague"
project: LASAGNA
secret_cookie_key: secure.key
version: v1

# test origin override
test_origin: http://localhost:80

# Google OAuth 2.0
goauth_origin: "https://lasagna.gscloud.cz"
goauth_redirect: "https://lasagna.gscloud.cz/login"
local_goauth_origin: "http://localhost:9000"
local_goauth_redirect: "http://localhost:9000/login"

# Google
google: []

# Umami Analytics
umami: []

# alpha/beta hosts
alpha_hosts: []
beta_hosts: []

# cache profiles
cache_profiles: []

# Redis
redis: [
  #database: 0
  #host: "127.0.0.1"
  #password: ""
  #persistent: true
  #unix_socket: ""

  # disable Redis
  port: 0
  #port: 6379
  timeout: 1
]

# CSS sources
css_sources: [
  "https://cdn.gscloud.cz/css/fontawesome.min.css",
  "https://cdn.gscloud.cz/css/brands.min.css",
  "https://cdn.gscloud.cz/css/solid.min.css",
]

# CSS extra sources
css_sources_extra: [
  "/css/style.css",
]

# script sources
script_sources: [
  "https://cdn.gscloud.cz/js/materialize.min.js",
  "https://cdn.gscloud.cz/js/lazysizes.min.js",
  "https://cdn.gscloud.cz/js/main.js",
]

# script extra sources
script_sources_extra: [
]

