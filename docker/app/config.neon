# Service Worker preload
swpreload: [
  "https://cdn.gscloud.cz/js/jquery.min.js"
  "https://cdn.gscloud.cz/css/materialize.min.css"
  "https://cdn.gscloud.cz/js/materialize.min.js"
  "https://cdn.gscloud.cz/js/main.js"
]

# Service Worker preload with CDN hash
swpreload_cdn: [
  "/css/style.css"
]
